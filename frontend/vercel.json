{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nexora-backend-1xq5.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://nexora-backend-1xq5.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
